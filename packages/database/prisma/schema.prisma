// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(cuid())
  name      String
  gstNumber String?
  phone     String?
  email     String?
  address   String?
  isArchived Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  customers    Customer[]
  payments     Payment[]
  integrations CompanyIntegration[]
  actionItems   ActionItem[]
  subscription Subscription?
  workflows    Workflow[]
  disputes     Dispute[]
  accountingIntegrations AccountingIntegration[]
}

model User {
  id                  String   @id @default(cuid())
  clerkId             String   @unique
  email               String   @unique
  name                String?
  role                UserRole @default(MEMBER)
  isAuthorizedByOwner Boolean  @default(false)
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tasks Task[]
  actionItems ActionItem[]
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model Customer {
  id                 String    @id @default(cuid())
  name               String
  creditBalance      Decimal   @db.Decimal(18, 2) @default(0)
  currency           String    @default("INR")
  phone              String?
  email              String?
  gstNumber          String?
  industry           String?
  riskScore          Int       @default(0)
  aiSummary          String?   @db.Text
  aiSummaryUpdatedAt DateTime?
  preferredLanguage  String?
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  invoices Invoice[]
  messages Message[]
  promises Promise[]
  tasks        Task[]
  portalTokens PortalAccessToken[]
  disputes     Dispute[]
}

model PortalAccessToken {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([tokenHash])
}

model CompanyIntegration {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  type      String // e.g., 'EMAIL', 'WHATSAPP'
  config    Json // Stores credentials and settings securely
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, type])
}

model Invoice {
  id                String        @id @default(cuid())
  currency          String        @default("INR")
  invoiceNumber     String
  amount            Decimal       @db.Decimal(18, 2)
  issueDate         DateTime
  dueDate           DateTime
  status            InvoiceStatus @default(PENDING)
  paidAt            DateTime?
  closedAt          DateTime?
  outstandingAmount Decimal       @db.Decimal(18, 2)
  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id])
  paymentAllocations PaymentAllocation[]
  workflowEnrollments WorkflowEnrollment[]
  disputes          Dispute[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([customerId, invoiceNumber])
  @@index([customerId, status, dueDate])
}

model Payment {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  amount         Decimal  @db.Decimal(18, 2)
  receivedAt     DateTime
  reference      String?
  idempotencyKey String?  @unique
  method         String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  allocations PaymentAllocation[]

  @@index([companyId, receivedAt])
}

model PaymentAllocation {
  id        String   @id @default(cuid())
  paymentId String
  invoiceId String
  amount    Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
}

enum InvoiceStatus {
  PENDING
  OVERDUE
  PARTIAL
  PAID
  DISPUTED
}

model Message {
  id            String           @id @default(cuid())
  customerId    String
  customer      Customer         @relation(fields: [customerId], references: [id])
  type          MessageType
  direction     MessageDirection
  content       String           @db.Text
  aiSummary     String?          @db.Text
  aiDraftReply  String?          @db.Text
  aiDraftStatus String?          @default("PENDING")
  whatsappId    String?          @unique
  timestamp     DateTime         @default(now())
  createdAt     DateTime         @default(now())

  promises Promise[]

  @@index([customerId, timestamp])
}

enum MessageType {
  WHATSAPP
  EMAIL
  NOTE
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

model Promise {
  id           String        @id @default(cuid())
  customerId   String
  customer     Customer      @relation(fields: [customerId], references: [id])
  messageId    String?
  message      Message?      @relation(fields: [messageId], references: [id])
  expectedDate DateTime
  amount       Decimal?      @db.Decimal(18, 2)
  status       PromiseStatus @default(PENDING)
  aiConfidence Float?
  createdByAI  Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum PromiseStatus {
  PENDING
  KEPT
  BROKEN
  RESCHEDULED
}

model Task {
  id         String     @id @default(cuid())
  customerId String
  customer   Customer   @relation(fields: [customerId], references: [id])
  assignedTo String?
  user       User?      @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  taskType   TaskType
  priority   Int        @default(50)
  reason     String
  dueDate    DateTime?
  status     TaskStatus @default(PENDING)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum ActionItemStatus {
  PENDING
  COMPLETED
  SNOOZED
}

model ActionItem {
  id        String           @id @default(cuid())
  title     String
  notes     String?
  priority  Int              @default(50)
  status    ActionItemStatus @default(PENDING)
  dueDate   DateTime?
  
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  deletedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, deletedAt])
  @@index([companyId, status])
  @@index([dueDate])
}

enum TaskType {
  CALL
  SEND_REMINDER
  ESCALATE
  FOLLOW_UP
  RECORD_PAYMENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SNOOZED
  DISMISSED
}

model ImportJob {
  id            String          @id @default(cuid())
  companyId     String
  fileName      String
  status        ImportJobStatus @default(PENDING)
  type          ImportType      @default(INVOICE)
  fileHash      String?
  totalRows     Int?
  processedRows Int?
  errorLog      String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum ImportType {
  INVOICE
  PAYMENT
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// Inbox Events (Durability & Idempotency)
// ─────────────────────────────────────────────────────────────────────────────
model InboxEvent {
  id              String        @id @default(cuid())
  provider        InboxProvider
  providerEventId String? // Extracted post-parsing (e.g. Meta message ID)
  companyId       String? // Tenant awareness for debugging
  payload         Json // Raw JSON payload
  headers         Json? // Useful for debugging webhook signatures
  signature       String?
  schemaVersion   Int           @default(1)

  status    InboxEventStatus @default(RECEIVED)
  attempts  Int              @default(0)
  lastError String?          @db.Text

  processedAt DateTime?
  receivedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([status, updatedAt])
}

enum InboxProvider {
  WHATSAPP
  STRIPE
  GMAIL
  OUTLOOK
  SLACK
  SHOPIFY
}

enum InboxEventStatus {
  RECEIVED
  QUEUED
  PROCESSING
  PROCESSED
  FAILED
  FAILED_PERMANENT // Poison messages that hit retry ceiling
  IGNORED
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  userId     String
  action     String   // e.g. "invoice.mark_paid", "team.role_changed"
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
}

model Subscription {
  id                   String             @id @default(cuid())
  companyId            String             @unique
  company              Company            @relation(fields: [companyId], references: [id])
  provider             String             @default("LEMON_SQUEEZY")
  providerCustomerId     String?            @unique
  providerSubscriptionId String?            @unique
  plan                 String             @default("FREE")
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

model AccountingIntegration {
  id                    String     @id @default(cuid())
  companyId             String
  company               Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider              String
  realmId               String?
  accessToken           String     @db.Text
  refreshToken          String     @db.Text
  tokenExpiresAt        DateTime
  refreshTokenExpiresAt DateTime?
  syncStatus            SyncStatus @default(PENDING)
  lastSyncAt            DateTime?
  errorDetails          String?    @db.Text
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  @@unique([companyId, provider])
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  steps       WorkflowStep[]
  enrollments WorkflowEnrollment[]
}

model WorkflowStep {
  id          String   @id @default(cuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  order       Int
  type        WorkflowStepType
  template    String?  @db.Text
  delayDays   Int      @default(0)
  enrollments WorkflowEnrollment[]
}

enum WorkflowStepType {
  EMAIL
  WHATSAPP
  TASK
}

model WorkflowEnrollment {
  id            String   @id @default(cuid())
  workflowId    String
  workflow      Workflow @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  currentStepId String?
  currentStep   WorkflowStep? @relation(fields: [currentStepId], references: [id], onDelete: SetNull)
  status        EnrollmentStatus @default(ACTIVE)
  nextActionAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([workflowId, invoiceId])
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model Dispute {
  id          String        @id @default(cuid())
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reason      String
  description String?       @db.Text
  status      DisputeStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@index([invoiceId])
  @@index([customerId])
  @@index([companyId, status])
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}
